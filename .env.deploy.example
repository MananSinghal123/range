# ── Required ────────────────────────────────────────────────────────────────
PRIVATE_KEY=0x...
OWNER_ADDRESS=0x...           # factory + vault owner (multisig recommended)
OPERATOR_ADDRESS=0x...        # keeper / rebalancer bot
SWAP_ROUTER=0x...             # CL swap router on Mezo

# ── Optional overrides (defaults shown) ─────────────────────────────────────
GUARDIAN_ADDRESS=             # defaults to OWNER_ADDRESS
FEE_RECIPIENT=                # defaults to OWNER_ADDRESS
POOL_ADDRESS=0x026dB82AC7ABf60Bf1a81317c9DbD63702B85850   # MUSD/BTC pool
POSITION_MANAGER=0x509Bc221df2B83927c695FA0bb0f5B21053C874c

# ── Seed deposit (optional — set all or omit all) ────────────────────────────
# Requires PRIVATE_KEY == OWNER_ADDRESS (deployer is owner).
# SEED_ASSETS is the token0 (MUSD) amount in wei deposited into EACH vault.
SEED_ASSETS=

# Initial position ticks for each vault (only used when SEED_ASSETS is set).
# Leave empty to deploy without an open position (call initializePosition later).
TIGHT_TICK_LOWER=
TIGHT_TICK_UPPER=
MEDIUM_TICK_LOWER=
MEDIUM_TICK_UPPER=
WIDE_TICK_LOWER=
WIDE_TICK_UPPER=
