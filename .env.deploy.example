# ── Required ──────────────────────────────────────────────────────────────────
# Deployer private key (pays gas for deployment)
PRIVATE_KEY=0x...

# Wallet that owns the vault (can pause, set fees, update strategy widths)
OWNER_ADDRESS=0x...

# Keeper-bot wallet address (calls rebalance())
OPERATOR_ADDRESS=0x...

# Aerodrome / Velodrome CL pool address
POOL_ADDRESS=0x254aa3A898071D6A2dA0DB11dA73b02B4646078F

# ERC20 name and symbol for vault shares
VAULT_NAME=Mezo Rebalancer
VAULT_SYMBOL=mREBAL

# ── Optional: performance fee ─────────────────────────────────────────────────
# Max 1000 (= 10%). Leave blank to skip fee setup.
# After deploy, owner must call applyPerformanceFee() once the 2-day timelock elapses.
# PERFORMANCE_FEE_BPS=100
# FEE_RECIPIENT=0x...

# ── Optional: override contract defaults ──────────────────────────────────────
# TWAP_SECONDS=300        # TWAP window for price manipulation check (default: 300)
# MAX_TWAP_TICKS=200      # Max tick deviation allowed between spot and TWAP (default: 200)
# SLIPPAGE_BPS=50         # Slippage tolerance in basis points (default: 50 = 0.5%)
