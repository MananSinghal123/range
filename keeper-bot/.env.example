PRIVATE_KEY=0xyour_private_key_here
RPC_URL=https://rpc.test.mezo.org
# Preferred — enables real event subscriptions instead of HTTP polling
WS_URL=wss://rpc.test.mezo.org

# Single vault
VAULT_ADDRESS=0x0000000000000000000000000000000000000000
POOL_ADDRESS=0x254aa3A898071D6A2dA0DB11dA73b02B4646078F
# Required — choose your strategy: 0=TIGHT, 1=MEDIUM, 2=WIDE
STRATEGY=

# Multi-vault (comma-separated, aligned by index — overrides single vault above)
# VAULT_ADDRS=0xVault1,0xVault2
# POOL_ADDRS=0xPool1,0xPool2
# STRATEGIES=0,2

# Optional tuning
POLL_INTERVAL_MS=30000
MAX_GAS_GWEI=50
